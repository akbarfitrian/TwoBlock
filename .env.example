# Wallet connection goes directly through MetaMask (or any other browser
# wallet) via window.ethereum (see src/hooks/useTwoBlockAuth.ts) — no App ID
# or secret is required for this.

# 'testnet' until Arc mainnet is officially released. Switch to 'mainnet'
# once the official chain ID & RPC are available and
# lib/arc/chain.ts::arcMainnet has been filled in.
NEXT_PUBLIC_ARC_NETWORK=testnet

# Optional. The public testnet RPC (rpc.testnet.arc.network) is shared by
# everyone and can hit rate limits ("request limit reached", code -32011)
# during busy periods. If you have a dedicated/private RPC endpoint for Arc
# testnet, set it here — it's used instead of the public one when adding
# the chain to the user's wallet. Leave empty to just use the public RPC.
NEXT_PUBLIC_ARC_RPC_URL=

# Supabase — from Project Settings > API on dashboard.supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEVER prefix the service role key with NEXT_PUBLIC_ — if it gets bundled
# into the client, anyone can bypass RLS and write directly to every table.
SUPABASE_SERVICE_ROLE_KEY=

# Giphy — powers the GIF picker in the post composer (GifPicker.tsx). Get a
# free key at developers.giphy.com. This is called directly from the
# browser (hence NEXT_PUBLIC_), so only use a key scoped for client-side use
# — never put a server-only secret here. Leave empty to hide the GIF picker.
NEXT_PUBLIC_GIPHY_API_KEY=

# Deployed address of contracts/TwoBlockPayments.sol on the active Arc
# network. Both tipping (sendTip.ts) and the OG membership purchase
# (useOG.ts) call this contract instead of sending a raw P2P transfer — see
# src/shared/contracts/two-block-payments.ts. Required for both flows to
# work. Run `npx hardhat run contracts/scripts/deploy.ts --network
# arcTestnet` to deploy and get this value.
NEXT_PUBLIC_PAYMENTS_CONTRACT_ADDRESS=

# Arc wallet address (EVM format, starting with 0x) that OG membership
# payments are forwarded to by the contract. Only used at contract *deploy
# time* now, as the constructor's initial treasury — see
# contracts/scripts/deploy.ts and src/backend/lib/og-treasury.ts. To change
# the treasury after deploy, call the contract's setTreasury() as the owner.
NEXT_PUBLIC_OG_TREASURY_WALLET=

# Private key of the wallet used to deploy contracts/TwoBlockPayments.sol
# (hardhat.config.ts). Needs Arc testnet/mainnet gas (USDC) to pay for
# deployment. NEVER commit this or prefix it with NEXT_PUBLIC_.
DEPLOYER_PRIVATE_KEY=
